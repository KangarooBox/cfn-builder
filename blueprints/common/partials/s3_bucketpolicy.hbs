{{!--
  Creates a policy to control access to an S3 bucket.

  http://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/aws-properties-s3-policy.html
 --}}
"s3bp{{sanitize this.Bucket ''}}" : {
  "Type" : "AWS::S3::BucketPolicy",
  "Properties": {
    {{#ifObject this.Bucket}}
      "Bucket": { {{{this.Bucket}}} }
    {{else}}
      "Bucket": { "Ref" : "s3b{{sanitize this.Bucket ''}}" }
    {{/ifObject}},
    "PolicyDocument" : { {{{inject this.PolicyDocument}}} }
  },
  "DependsOn":"s3b{{sanitize this.Bucket ''}}"
}
